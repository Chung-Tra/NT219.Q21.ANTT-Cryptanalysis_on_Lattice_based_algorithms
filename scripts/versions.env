#!/usr/bin/env bash
# =============================================================================
# versions.env - Single source of truth for toolchain versions and paths.
# (Reproducibility requirement: brief section 7.3 - pin versions.)
# =============================================================================
export PQC_ROOT="$HOME/pqc"            # everything installs under $HOME: no sudo
export SRC_ROOT="$PQC_ROOT/src"        # third-party sources cloned here (outside repo)
export OSSL_PREFIX="$PQC_ROOT/openssl"
export LIBOQS_PREFIX_REF="$PQC_ROOT/liboqs-ref"    # WP3: portable C build
export LIBOQS_PREFIX_OPT="$PQC_ROOT/liboqs-neon"   # WP3: NEON/optimized build
export OQSPROVIDER_PREFIX="$PQC_ROOT/oqs-provider" # TLS provider (OQS fork successor)

export OPENSSL_TAG="openssl-3.6.2"
export LIBOQS_TAG="0.14.0"
export OQSPROVIDER_TAG="0.10.0"
# PQClean has no release tags: pin by recording the commit (fetch_pqclean.sh).

export JOBS="$(nproc)"

# nginx for WP4 macrobenchmark (official mirror github.com/nginx/nginx)
NGINX_TAG="release-1.30.2"
NGINX_PREFIX="$HOME/pqc/nginx"
